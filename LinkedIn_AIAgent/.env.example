# LinkedIn Job Agent — Environment Variables
# Copy this file to .env and fill in your keys (no quotes needed)

# ── Required ──────────────────────────────────────────────────
# Anthropic API key (get from console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ScraperAPI key for bypassing LinkedIn bot detection
# Free tier: 5,000 requests/month — enough for daily job hunting
# Sign up at: https://www.scraperapi.com
SCRAPER_API_KEY=your_scraperapi_key_here

# ── Optional ──────────────────────────────────────────────────
# Proxycurl API key (richer LinkedIn profile data, paid)
# https://nubela.co/proxycurl
PROXYCURL_API_KEY=

# Default search location (can be overridden per query)
DEFAULT_LOCATION=Remote

# Max jobs to fetch per search (keep ≤30 to avoid rate limits)
MAX_JOBS=20
